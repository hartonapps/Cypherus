# Comma-separated numeric Telegram user IDs allowed to use admin commands.
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# Optional: token for control-bot flow (currently not used in frontend-only runtime).
CONTROL_BOT_TOKEN=

# Optional: AI Horde API key for higher limits.
AI_HORDE_API_KEY=

# Optional: official links for future automation/features.
OFFICIAL_CHANNEL_USERNAME=
OFFICIAL_GROUP_USERNAME=
